# Copy to .env and adjust for your environment:
#   cp .env.example .env

# InfluxDB connection (points at the puda-logger influxdb service)
INFLUXDB_URL=http://bearsnas:8181
INFLUXDB_TOKEN=apiv3_puda
INFLUXDB_PUDA_DATABASE=puda
INFLUXDB_HERMES_DATABASE=hermes-logs
INFLUXDB_ORGANIZATION=bears

# IMRE MOF machine health telemetry source
NATS_IMRE_MOF_URL=nats://172.31.8.193:4222

# IMRE Pescardo machine health telemetry source
NATS_IMRE_PESCARDO_URL=nats://100.99.243.61:4222

# Grafana admin credentials
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
