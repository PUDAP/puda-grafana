INFLUXDB_DATABASE=machines

NATS_SERVERS=nats://localhost:4222,nats://localhost:4223,nats://localhost:4224

GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
