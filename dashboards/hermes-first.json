        {
          "datasource": { "type": "influxdb", "uid": "influxdb-puda" },
          "rawSql": "SELECT time, REPLACE(topic, 'response.', '') || '_' || msg_type AS \"Machine\" FROM machine_commands WHERE machine_id = 'first' AND $__timeFilter(time) ORDER BY time ASC",
          "refId": "F",
          "rawQuery": true
        }
      ],
