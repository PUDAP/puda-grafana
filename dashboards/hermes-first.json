    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Agent Timeline",
      "type": "row"
    },
    {
      "datasource": {
        "type": "datasource",
        "uid": "-- Mixed --"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "fillOpacity": 80,
            "lineWidth": 1,
            "spanNulls": false
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "start":          { "text": "start",          "color": "green",             "index": 0 },
                "end":            { "text": "end",            "color": "blue",              "index": 1 },
                "turn_start":     { "text": "turn_start",     "color": "#FADE2A",           "index": 2 },
                "turn_end":       { "text": "turn_end",       "color": "super-light-purple","index": 3 },
                "subagent_start": { "text": "subagent_start", "color": "purple",            "index": 4 },
                "subagent_stop":  { "text": "subagent_stop",  "color": "dark-purple",       "index": 5 }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Session" },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "View session detail (all tags/fields)",
                    "url": "/d/hermes-first/hermes-first?viewPanel=11&var-event_time=${__value.time}",
                    "targetBlank": false,
                    "oneClick": true
                  }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "LLM Turn" },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "View LLM turn detail (all tags/fields)",
                    "url": "/d/hermes-first/hermes-first?viewPanel=12&var-event_time=${__value.time}",
                    "targetBlank": false,
                    "oneClick": true
                  }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Tool Call" },
            "properties": [
              { "id": "color", "value": { "mode": "palette-classic" } },
              {
                "id": "mappings",
                "value": [
                  { "type": "regex", "options": { "pattern": "^tool_(start|end): terminal\\b", "result": { "color": "blue", "index": 0 } } },
                  { "type": "regex", "options": { "pattern": "^tool_(start|end): read_file\\b", "result": { "color": "green", "index": 1 } } },
                  { "type": "regex", "options": { "pattern": "^tool_(start|end): search_files\\b", "result": { "color": "orange", "index": 2 } } },
                  { "type": "regex", "options": { "pattern": "^tool_(start|end): skill_view\\b", "result": { "color": "purple", "index": 3 } } },
                  { "type": "regex", "options": { "pattern": "^tool_(start|end): execute_code\\b", "result": { "color": "red", "index": 4 } } }
                ]
              },
              {
                "id": "links",
                "value": [
                  {
                    "title": "View tool call detail (args/result)",
                    "url": "/d/hermes-first/hermes-first?viewPanel=10&var-event_time=${__value.time}",
                    "targetBlank": false,
                    "oneClick": true
                  }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "API Request" },
