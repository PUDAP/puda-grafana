        {
          "datasource": { "type": "influxdb", "uid": "influxdb-hermes-first" },
          "rawSql": "SELECT time, event AS \"Session\" FROM hermes_session WHERE $__timeFilter(time) ORDER BY time ASC",
          "refId": "A",
          "rawQuery": true
        },
        {
          "datasource": { "type": "influxdb", "uid": "influxdb-hermes-first" },
          "rawSql": "SELECT time, event AS \"LLM Turn\" FROM hermes_llm_turn WHERE $__timeFilter(time) ORDER BY time ASC",
          "refId": "B",
          "rawQuery": true
        },
        {
          "datasource": { "type": "influxdb", "uid": "influxdb-hermes-first" },
          "rawSql": "SELECT time, model AS \"API Request\" FROM hermes_api_request WHERE $__timeFilter(time) ORDER BY time ASC",
          "refId": "C",
          "rawQuery": true
        },
        {
          "datasource": { "type": "influxdb", "uid": "influxdb-hermes-first" },
          "rawSql": "SELECT time, event || ': ' || tool_name AS \"Tool Call\" FROM hermes_tool_call WHERE $__timeFilter(time) ORDER BY time ASC",
          "refId": "D",
          "rawQuery": true
        },
        {
          "datasource": { "type": "influxdb", "uid": "influxdb-hermes-first" },
          "rawSql": "SELECT time, event AS \"Subagent\" FROM hermes_subagent WHERE $__timeFilter(time) ORDER BY time ASC",
          "refId": "E",
          "rawQuery": true
