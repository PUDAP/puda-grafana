        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb-puda" },
          "rawSql": "SELECT now() AS time, CAST(COUNT(CASE WHEN status = 'success' THEN 1 END) AS DOUBLE) * 100.0 / NULLIF(COUNT(*), 0) AS \"Success Rate\" FROM machine_commands WHERE msg_type = 'response' AND $__timeFilter(time) AND machine_id IN (${machine_id:singlequote})",
          "refId": "A",
          "rawQuery": true
        }
      ],
      "title": "Success Rate",
      "type": "stat"
    },
    {
      "datasource": { "type": "influxdb", "uid": "influxdb-puda" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red",   "value": 1 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb-puda" },
          "rawSql": "SELECT now() AS time, COUNT(*) AS \"Errors\" FROM machine_commands WHERE status = 'error' AND $__timeFilter(time) AND machine_id IN (${machine_id:singlequote})",
          "refId": "A",
          "rawQuery": true
        }
      ],
      "title": "Errors",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Activity",
      "type": "row"
    },
    {
      "datasource": { "type": "influxdb", "uid": "influxdb-puda" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 1,
            "pointSize": 4,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "normal" },
            "barAlignment": 0
          },
          "unit": "short",
          "min": 0
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "biologic" },
            "properties": [{ "id": "displayName", "value": "Biologic" }]
          },
          {
            "matcher": { "id": "byName", "options": "first" },
            "properties": [{ "id": "displayName", "value": "First" }]
          },
          {
            "matcher": { "id": "byName", "options": "opentrons" },
            "properties": [{ "id": "displayName", "value": "Opentrons" }]
          },
          {
            "matcher": { "id": "byName", "options": "Errors" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } },
              { "id": "custom.drawStyle", "value": "line" },
              { "id": "custom.stacking", "value": { "group": "A", "mode": "none" } },
              { "id": "custom.fillOpacity", "value": 0 },
              { "id": "custom.lineWidth", "value": 2 }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
      "id": 5,
      "options": {
        "legend": {
          "calcs": ["sum"],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb-puda" },
          "rawSql": "SELECT date_bin(INTERVAL '1 minute', time, TIMESTAMP '1970-01-01 00:00:00Z') AS time, COUNT(CASE WHEN machine_id = 'biologic' THEN 1 END) AS biologic, COUNT(CASE WHEN machine_id = 'first' THEN 1 END) AS first, COUNT(CASE WHEN machine_id = 'opentrons' THEN 1 END) AS opentrons FROM machine_commands WHERE msg_type = 'command' AND $__timeFilter(time) GROUP BY 1 ORDER BY 1 ASC",
          "refId": "A",
          "rawQuery": true
        },
        {
          "datasource": { "type": "influxdb", "uid": "influxdb-puda" },
          "rawSql": "SELECT date_bin(INTERVAL '1 minute', time, TIMESTAMP '1970-01-01 00:00:00Z') AS time, COUNT(*) AS \"Errors\" FROM machine_commands WHERE status = 'error' AND $__timeFilter(time) AND machine_id IN (${machine_id:singlequote}) GROUP BY 1 ORDER BY 1 ASC",
          "refId": "B",
          "rawQuery": true
        }
      ],
      "title": "Commands per Minute by Machine",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "title": "Command Log",
      "type": "row"
    },
    {
      "datasource": { "type": "influxdb", "uid": "influxdb-puda" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false,
            "minWidth": 50,
            "filterable": true
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "time" },
            "properties": [
              { "id": "displayName", "value": "Time" },
              { "id": "custom.width", "value": 180 },
              { "id": "unit", "value": "dateTimeAsLocal" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "machine_id" },
            "properties": [
              { "id": "displayName", "value": "Machine" },
              { "id": "custom.width", "value": 100 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "msg_type" },
            "properties": [
              { "id": "displayName", "value": "Type" },
              { "id": "custom.width", "value": 90 },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "command":  { "text": "CMD",  "color": "blue",  "index": 0 },
                      "response": { "text": "RESP", "color": "purple", "index": 1 }
                    }
                  }
                ]
              },
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "basic" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "command" },
            "properties": [
              { "id": "displayName", "value": "Command" },
              { "id": "custom.width", "value": 180 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "status" },
            "properties": [
              { "id": "displayName", "value": "Status" },
              { "id": "custom.width", "value": 90 },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "sent":    { "text": "Sent",    "color": "blue",  "index": 0 },
                      "success": { "text": "Success", "color": "green", "index": 1 },
                      "error":   { "text": "Error",   "color": "red",   "index": 2 }
                    }
                  }
                ]
              },
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "basic" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "step" },
            "properties": [
              { "id": "displayName", "value": "Step" },
              { "id": "custom.width", "value": 60 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "username" },
            "properties": [
              { "id": "displayName", "value": "User" },
              { "id": "custom.width", "value": 110 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "run_id" },
            "properties": [
              { "id": "displayName", "value": "Run ID" },
              { "id": "custom.width", "value": 120 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "message" },
            "properties": [
              { "id": "displayName", "value": "Message / Error" },
              { "id": "custom.width", "value": 260 },
              { "id": "custom.cellOptions", "value": { "type": "auto", "wrapText": true } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "params" },
            "properties": [
              { "id": "displayName", "value": "Params" },
              { "id": "custom.cellOptions", "value": { "type": "auto", "wrapText": true } }
            ]
          }
        ]
      },
      "gridPos": { "h": 18, "w": 24, "x": 0, "y": 15 },
      "id": 6,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": ["sum"],
          "show": false
        },
        "frameIndex": 0,
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Time" }]
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb-puda" },
          "rawSql": "SELECT time, machine_id, msg_type, COALESCE(cmd_name, '') AS command, status, COALESCE(CAST(step_number AS VARCHAR), '') AS step, username, COALESCE(run_id, '') AS run_id, COALESCE(substr(data_json, 1, 300), '') AS message, COALESCE(substr(params_json, 1, 300), '') AS params FROM machine_commands WHERE $__timeFilter(time) AND machine_id IN (${machine_id:singlequote}) AND ('${msg_type}' = 'All' OR msg_type = '${msg_type}') AND ('${status}' = 'All' OR status = '${status}') AND ('${run_id}' = '' OR run_id = '${run_id}') ORDER BY time DESC LIMIT 500",
          "refId": "A",
          "rawQuery": true
        }
      ],
      "title": "Command Log  (latest 500)",
      "type": "table"
    },
    {
