      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb-puda" },
          "rawSql": "SELECT now() AS time, COUNT(*) AS \"Commands Sent\" FROM machine_commands WHERE msg_type = 'command' AND $__timeFilter(time) AND machine_id IN (${machine_id:singlequote})",
          "refId": "A",
          "rawQuery": true
        }
