          "refId": "A",
          "rawQuery": true
        }
      ],
      "title": "Responses Received",
      "type": "stat"
    },
    {
      "datasource": { "type": "influxdb", "uid": "influxdb-puda" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "orange", "value": 70 },
              { "color": "green",  "value": 95 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 3,
