      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb-puda" },
          "query": "from(bucket: \"machines\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"machine_status\" and r._field == \"status\")\n  |> keep(columns: [\"_time\", \"_value\", \"machine_id\"])\n  |> pivot(rowKey: [\"_time\"], columnKey: [\"machine_id\"], valueColumn: \"_value\")",
          "refId": "A"
