                "running":   { "text": "Running",    "color": "green",  "index": 3 },
                "succeeded": { "text": "Succeeded",  "color": "green",  "index": 4 },
                "paused":    { "text": "Paused",     "color": "yellow", "index": 5 },
                "stopped":   { "text": "Stopped",    "color": "orange", "index": 6 },
                "failed":    { "text": "Failed",     "color": "red",    "index": 7 },
                "error":     { "text": "Error",      "color": "orange", "index": 8 }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "biologic" },
            "properties": [{ "id": "displayName", "value": "Biologic" }]
