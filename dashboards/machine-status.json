          "color": { "mode": "thresholds" },
          "custom": {
            "fillOpacity": 80,
            "lineWidth": 1,
            "spanNulls": false
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "online":    { "text": "Online",    "color": "green",  "index": 0 },
                "offline":   { "text": "Offline",   "color": "red",    "index": 1 },
